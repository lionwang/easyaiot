# 复制为 .env 后按需填写（脚本本身用命令行参数，本文件仅备忘）
MQTT_HOST=localhost
MQTT_PORT=1883
PRODUCT=your_product_identification
DEVICE=your_device_identification
TENANT_ID=1
PASSWORD=your_product_password

# ============================================
# 抓拍算法服务环境变量配置模板
# ============================================
# 使用方法：
# 1. 复制此文件为 .env: cp env.example .env
# 2. 根据实际情况修改各个配置项
# 3. 注意：.env 文件包含敏感信息，不要提交到版本控制系统
# ============================================
#
# 与 stream_forward / realtime_algorithm 一致的读取优先级（抓拍不推流，无 FFmpeg 编码）：
# - 帧率/分辨率：AI_SOURCE_FPS、AI_TARGET_* → VIEW_SOURCE_FPS、VIEW_TARGET_* → SOURCE_FPS、TARGET_*
# - 画质档位：AI_VIDEO_QUALITY_PROFILE → VIEW_VIDEO_QUALITY_PROFILE → VIDEO_QUALITY_PROFILE
# 代码未使用 FFMPEG_PRESET / FFMPEG_VIDEO_BITRATE 等推流相关变量，无需配置。

# ============================================
# 基本配置（必需）
# ============================================
# 算法任务ID（必需）
TASK_ID=

# 数据库配置
DATABASE_URL=postgresql://postgres:iot45722414822@localhost:5432/iot-video

# 视频服务端口（默认6000）
VIDEO_SERVICE_PORT=6000

# 网关地址
GATEWAY_URL=http://localhost:48080

# ============================================
# 视频处理（可选；不配则与代码默认一致：25fps、1280x720）
# ============================================
# 以下为低配示例，若要与推流转发同款清晰度可改为 25、1280、720 或删除以使用默认
# AI_SOURCE_FPS=25
# AI_TARGET_WIDTH=1280
# AI_TARGET_HEIGHT=720
# VIEW_SOURCE_FPS=25
# VIEW_TARGET_WIDTH=1280
# VIEW_TARGET_HEIGHT=720
SOURCE_FPS=15
TARGET_WIDTH=640
TARGET_HEIGHT=360

# 抽帧间隔（默认2；抓拍任务还受 cron 控制）
EXTRACT_INTERVAL=2

BUFFER_SIZE=70
MIN_BUFFER_FRAMES=15
MAX_WAIT_TIME=0.08

# YOLO 输入边长（letterbox；画质分档会覆盖部分预设）
YOLO_IMG_SIZE=416

# 抓拍：单设备抽帧队列深度（代码默认1，新顶旧）
EXTRACT_QUEUE_SIZE=1

# 检测结果最大等待（秒），超时未出结果则丢弃该帧上下文
SNAPSHOT_RESULT_MAX_WAIT_SEC=5.0

# ============================================
# 队列与检测线程
# ============================================
DETECTION_QUEUE_SIZE=100
PUSH_QUEUE_SIZE=100
YOLO_WORKER_THREADS=2

# ============================================
# 其他
# ============================================
PYTHONUNBUFFERED=1
TZ=Asia/Shanghai
